<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.TeamMemberMapper">

    <select id="list" resultType="com.itheima.pojo.TeamMember">
        SELECT tm.*, u.real_name as student_name, u.student_id as student_id_str
        FROM team_member tm
        LEFT JOIN user u ON tm.student_id = u.id
        <where>
            <if test="teamId != null">
                AND tm.team_id = #{teamId}
            </if>
        </where>
        ORDER BY tm.join_time ASC
    </select>

    <insert id="insert" parameterType="com.itheima.pojo.TeamMember" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO team_member (team_id, student_id, role)
        VALUES (#{teamId}, #{studentId}, #{role})
    </insert>

    <delete id="delete">
        DELETE FROM team_member WHERE id = #{id}
    </delete>

    <delete id="deleteByTeamId">
        DELETE FROM team_member WHERE team_id = #{teamId}
    </delete>

</mapper>
